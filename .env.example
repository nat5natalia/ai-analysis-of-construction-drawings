# OpenAI API Key (обязательно для работы агента)
OPENAI_API_KEY=your_openai_api_key_here
# PostgreSQL (опционально - работает с дефолтными значениями)
DATABASE_URL=postgresql://postgres:postgres@postgres:5432/langgraph_db

# Device mode for drawing_agent:
# cpu - always use CPU
# cuda - require GPU, fail if CUDA is unavailable
# auto - use GPU if available, otherwise CPU
AGENT_DEVICE=cpu

# PyTorch package index used while building drawing_agent image.
# CPU:
TORCH_INDEX_URL=https://download.pytorch.org/whl/cpu

# GPU CUDA 12.1:
# TORCH_INDEX_URL=https://download.pytorch.org/whl/cu121
